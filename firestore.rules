// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 가족 구성원 - 로그인한 사용자만 읽기, 자신의 문서만 수정
    match /members/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 점수는 Cloud Functions 또는 배치로만 수정 (서비스에서 직접 처리)
    // 여기서는 간단하게 로그인 사용자 전체 허용
    match /members/{userId} {
      allow update: if request.auth != null;
    }

    // 규칙 - 로그인한 사용자 읽기, 부모만 쓰기
    match /rules/{ruleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'parent';
    }

    // 요청 - 로그인한 사용자 읽기/생성, 본인 제외 수정 가능
    match /requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        resource.data.requestedBy != request.auth.uid;
    }

    // 우승 기록 - 로그인한 사용자 읽기/생성 (우승자 승인 시 생성됨)
    match /winners/{winnerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
  }
}
